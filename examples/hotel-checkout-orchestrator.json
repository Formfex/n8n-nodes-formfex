          "mode": "id"
        },
        "text": "=:clipboard: *Guest Feedback (Neutral)*\n\n*Summary:* {{ $json.summary }}\n*Positives:* {{ $json.positives }}\n*Negatives:* {{ $json.negatives }}",
        "otherOptions": {}
      },
      "id": "wf27-slack-neutral",
      "name": "Slack: Daily Feedback",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [
        1100,
        1200
      ],
      "credentials": {
        "slackApi": {
          "id": "YOUR_SLACK_CREDENTIAL_ID",
          "name": "Slack"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "feedback@formfex.com",
        "toEmail": "={{ $json.guestEmail || 'guest@example.com' }}",
        "subject": "Thank you for your wonderful feedback!",
        "emailType": "html",
