{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": false,
    "resolveJsonModule": true
  },
  "include": [
    "index.ts",
    "credentials/**/*.ts",
    "nodes/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "test"]
}
